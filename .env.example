OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=carousel-agents

# OpenRouter model ids
# Ideation: extract + score + shortlist governance + carousel critique (when enabled)
MODEL_IDEATION=mistralai/mistral-large
# Split ideation (--split-ideation): optional overrides (fallback chain: these → MODEL_IDEATION → MODEL_JUDGE → defaults)
# MODEL_IDEATION_EXTRACT=openai/gpt-4.1-mini
# MODEL_IDEATION_SCORE=mistralai/mistral-large
# TEMP_IDEATION_EXTRACT=0.1
# TEMP_IDEATION_SCORE=0.1
# Legacy alias (optional): if set and MODEL_IDEATION is empty, same as before MODEL_JUDGE-only setups
# MODEL_JUDGE=mistralai/mistral-large
# Hook Judge: only used when you enable hook policy (--hook-policy). Default model: mistral-large.
MODEL_HOOK_JUDGE=mistralai/mistral-large
MODEL_WRITER=google/gemini-2.5-pro-preview
MODEL_EDITOR=openai/gpt-4.1-mini
# Experiment orchestrator (`orchestrate suggest --llm`); defaults to MODEL_IDEATION chain if unset
# MODEL_ORCHESTRATOR=mistralai/mistral-large

# Optional temperatures (defaults are sensible per role)
# TEMP_IDEATION=0.1
# TEMP_JUDGE=0.1
# TEMP_HOOK_JUDGE=0.0
# TEMP_WRITER=0.6
# TEMP_EDITOR=0.2

# Vision model for OCR (OpenRouter)
MODEL_OCR=google/gemini-3-flash-preview

# Optional override (for other OpenAI-compatible providers)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Structured outputs (Instructor): retries when a stage's JSON fails Pydantic validation
# INSTRUCTOR_MAX_RETRIES=3

# Optional (for downloading IG posts via Instaloader; recommended for reliability)
IG_USERNAME=
IG_PASSWORD=

# Personas (optional): JSON cards under PERSONAS_DIR; rule-based proxy for log-performance
# PERSONAS_DIR=docs/personas
# PERSONA_RULES_PATH=data/persona_rules.json

# Default paths (override hardcoded repo-relative defaults)
# CAROUSEL_PERFORMANCE_JSONL=data/performance.jsonl
# CAROUSEL_TAGS_JSONL=exports/instagram/_dataset/carousel_tags.jsonl
# CAROUSEL_OCR_SLIDES_JSONL=exports/instagram/_dataset/ocr_slides.jsonl
# CAROUSEL_PERFORMANCE_DIGEST_JSON=outputs/performance_digest.json
# CAROUSEL_MARKETING_TRACKER_CSV=Marketing - Content - Tracker - Content Tracker (1).csv
# CAROUSEL_EXPORT_DIR=outputs
# CAROUSEL_RUN_JSON=data/run.json
# CAROUSEL_PERFORMANCE_NORMALIZED_JSONL=data/performance.normalized.jsonl

# Parallel writer stages (hooks+CTA per selected idea); 1 = sequential
# CAROUSEL_MAX_PARALLEL=1

# Evidence pack: max chars per chunk in writer SOURCE TEXT (0/none/off = unlimited)
# WRITER_EVIDENCE_MAX_CHUNK_CHARS=16000

# Structured pipeline + LLM logs (latency; usage on JSON chat path when returned)
# CAROUSEL_LOG_LEVEL=INFO
